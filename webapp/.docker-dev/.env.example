# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.

# Base URL of the charity-chest API server reachable from the browser.
# When running the server via its own docker-compose, use http://localhost:8080.
# NEXT_PUBLIC_ prefix is required — Next.js inlines this value into the browser bundle.
NEXT_PUBLIC_API_URL=http://localhost:8080
