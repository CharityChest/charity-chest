BINARY  := server
DEBUG   := dist/debug/$(BINARY)
RELEASE := dist/release/$(BINARY)

# golang-migrate is already in go.mod — no separate install needed.
MIGRATE      := go run -tags 'postgres' github.com/golang-migrate/migrate/v4/cmd/migrate
GOLANGCI_LINT := go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4
# Keep this in sync with the templ version in go.mod so the CLI matches the
# runtime package that is linked into the binary.
TEMPL_VERSION := v0.3.1020
TEMPL         := go run github.com/a-h/templ/cmd/templ@$(TEMPL_VERSION)

.PHONY: all build build-debug build-release test test-coverage lint fmt clean tidy seed-root migrate migrate-down migrate-version templ

# ── Default ───────────────────────────────────────────────────────────────────

all: build

build: build-debug build-release

# ── Debug build ───────────────────────────────────────────────────────────────
# Optimisations and inlining are disabled so the binary is debugger-friendly.
# The race detector is enabled to catch data races during development.
# `templ` runs first so the generated *_templ.go files are always in sync with
# the .templ sources before the compiler reads them.

build-debug: templ
	@mkdir -p dist/debug
	go build \
	  -race \
	  -gcflags="all=-N -l" \
	  -o $(DEBUG) \
	  .
	@echo "debug binary → $(DEBUG)"

# ── Release build ─────────────────────────────────────────────────────────────
# Produces a fully static binary with debug info and symbol table stripped.
# `templ` runs first so the binary cannot ship with a stale generated file.

build-release: templ
	@mkdir -p dist/release
	CGO_ENABLED=0 GOOS=linux go build \
	  -ldflags="-s -w" \
	  -o $(RELEASE) \
	  .
	@echo "release binary → $(RELEASE)"

# ── Helpers ───────────────────────────────────────────────────────────────────

test:
	go test -race ./internal/...

# Report coverage across all production packages, excluding files that cannot
# carry meaningful coverage:
#   - main.go and cmd/* are thin entry points exercised only end-to-end;
#   - *_templ.go is generated by templ — its statements are tied to the
#     template source, not to logic we can usefully unit-test.
# `-coverpkg=./...` cross-instruments every package so coverage triggered by
# integration tests in routes/v1 counts against the file that owns the code.
# The result is `coverage.business.out`; the raw report is `coverage.out`.
test-coverage:
	go test -race -coverpkg=./... -coverprofile=coverage.out ./...
	@grep -v -E '(charity-chest/main\.go|charity-chest/cmd/|_templ\.go)' coverage.out > coverage.business.out
	@echo "── full coverage ──"
	@go tool cover -func=coverage.out | tail -1
	@echo "── coverage excluding entry points and generated code ──"
	@go tool cover -func=coverage.business.out | tail -1

lint:
	$(GOLANGCI_LINT) run ./...

fmt:
	gofmt -w .
	$(GOLANGCI_LINT) run --fix ./...

tidy:
	go mod tidy

# Regenerate the *_templ.go files from .templ sources. Commit both the .templ
# and the generated *_templ.go file — the generated file is checked in so
# `go build` works without a separate codegen step.
templ:
	$(TEMPL) generate

clean:
	rm -rf dist

# ── Seed ──────────────────────────────────────────────────────────────────────
# Creates a root user in the database.
# Usage: make seed-root EMAIL=admin@example.com PASSWORD=secret

seed-root:
	@test -n "$(EMAIL)"    || (echo "ERROR: EMAIL is required";    exit 1)
	@test -n "$(PASSWORD)" || (echo "ERROR: PASSWORD is required"; exit 1)
	SEED_ROOT_EMAIL=$(EMAIL) SEED_ROOT_PASSWORD=$(PASSWORD) \
	  go run ./cmd/seed-root/main.go -migrations migrations

# ── Migrations ────────────────────────────────────────────────────────────────
# DATABASE_URL must be set in the environment or .env.

# Apply all pending migrations.
migrate:
	@test -n "$(DATABASE_URL)" || (echo "ERROR: DATABASE_URL is required"; exit 1)
	$(MIGRATE) -path migrations -database "$(DATABASE_URL)" up

# Roll back N migration steps.
# Usage: make migrate-down N=1
migrate-down:
	@test -n "$(DATABASE_URL)" || (echo "ERROR: DATABASE_URL is required"; exit 1)
	@test -n "$(N)" || (echo "ERROR: N is required (e.g. make migrate-down N=1)"; exit 1)
	$(MIGRATE) -path migrations -database "$(DATABASE_URL)" down $(N)

# Print the current migration version.
migrate-version:
	@test -n "$(DATABASE_URL)" || (echo "ERROR: DATABASE_URL is required"; exit 1)
	$(MIGRATE) -path migrations -database "$(DATABASE_URL)" version