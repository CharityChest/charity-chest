# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/charitychest?sslmode=disable

# HS256 signing secret for JWTs — use a long, random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth 2.0 credentials (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback

# Base URL of the webapp — used to redirect back after Google OAuth
FRONTEND_URL=http://localhost:3000

# HTTP listen port
PORT=8080

# Per-request access log (Echo's RequestLogger middleware). Set to "false" to silence it.
REQUEST_LOG_ENABLED=true

# Cache (Valkey/Redis-compatible)
# Set CACHE_ENABLED=true and run a local Valkey: docker run -p 6379:6379 valkey/valkey:8-alpine
CACHE_ENABLED=false
CACHE_URL=redis://localhost:6379
CACHE_TTL=5m

# SMTP — outbound email for the password-recovery flow.
# Leave SMTP_HOST empty to disable email entirely (the forgot-password endpoint
# still returns the neutral 204 response and logs a server-side warning).
# In dev, point at Mailpit: SMTP_HOST=localhost SMTP_PORT=1025 (no credentials).
# In staging/production, point at a real relay (SES, Mailgun, Postmark, etc.).
# SMTP_USERNAME / SMTP_PASSWORD are an optional pair: set both or neither.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@charitychest.local
SMTP_FROM_NAME=Charity Chest
# Force the SMTP client to dial over IPv4 only. Defaults to true: many
# self-hosted relays publish unreachable AAAA records, which makes the
# default dual-stack dial silently time out after 30s. Set to "false" only
# if your relay's IPv6 path is verified.
SMTP_FORCE_IPV4=true